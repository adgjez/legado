<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/web_view_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="#66000000"
        android:visibility="invisible" />

    <FrameLayout
        android:id="@+id/native_sheet_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="bottom"
        android:background="@color/dialog_surface"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/web_view_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <FrameLayout
            android:id="@+id/web_view_placeholder"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_web_view_loading_circle"
            android:elevation="8dp"
            android:padding="20dp">

            <io.legado.app.lib.theme.view.ThemeProgressBar
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminateBehavior="repeat"
                android:indeterminateOnly="true" />

        </FrameLayout>

    </FrameLayout>

    <FrameLayout
        android:id="@+id/custom_web_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
